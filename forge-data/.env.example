# ════════════════════════════════════════════════════════════════════════════
# FORGE Data — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Lines starting with # are comments.
# Never commit your .env file — it is listed in .gitignore.
# ════════════════════════════════════════════════════════════════════════════

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://forge:forge@postgres:5432/forge
REDIS_URL=redis://redis:6379/0

# ── MinIO / Object Storage ────────────────────────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=forge
MINIO_SECRET_KEY=forgedata123
MINIO_BUCKET=forge-data
MINIO_USE_SSL=false

# ── Jupyter ───────────────────────────────────────────────────────────────────
# Gateway URL used by the API to execute cells
JUPYTER_GATEWAY_URL=http://jupyter:8888
# Token for production deployments (leave empty for local dev)
JUPYTER_TOKEN=

# ── MLflow ────────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://mlflow:5000

# ── Authentication ────────────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -hex 32
JWT_SECRET=change-me-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ── BYOK — LLM Provider Keys ──────────────────────────────────────────────────
# FORGE Data supports Bring Your Own Key (BYOK). Users can supply their own
# keys via the UI. These variables act as platform-level defaults / fallbacks.
# Leave blank if you want to require per-user keys.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=

# Ollama — self-hosted local LLM (no key required)
OLLAMA_BASE_URL=http://localhost:11434

# Azure OpenAI (optional BYOK target)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-02-01

# ── Application ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost/api
NEXT_PUBLIC_WS_URL=ws://localhost/api/ws
NODE_ENV=development
APP_ENV=development

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost

# ── Feature Flags ─────────────────────────────────────────────────────────────
FEATURE_MLFLOW_ENABLED=true
FEATURE_JUPYTER_ENABLED=true
FEATURE_CONNECTORS_ENABLED=true
