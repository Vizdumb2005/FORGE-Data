# ════════════════════════════════════════════════════════════════════════════
# FORGE Data — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Never commit your .env file — it is listed in .gitignore.
# ════════════════════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_DB=forge
POSTGRES_USER=forge
# REQUIRED — change this in any non-local deployment
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql://forge:change-me@postgres:5432/forge
REDIS_URL=redis://redis:6379/0

# ── MinIO / Object Storage ────────────────────────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=forge
# REQUIRED — change this in any non-local deployment
MINIO_SECRET_KEY=change-me
MINIO_BUCKET=forge-data
MINIO_USE_SSL=false

# ── Jupyter ───────────────────────────────────────────────────────────────────
JUPYTER_GATEWAY_URL=http://jupyter:8888
# Set a token for production: openssl rand -hex 32
JUPYTER_TOKEN=

# ── MLflow ────────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://mlflow:5000
# Must match POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB above
MLFLOW_BACKEND_STORE_URI=postgresql://forge:change-me@postgres/forge_mlflow

# ── Authentication ────────────────────────────────────────────────────────────
# REQUIRED — generate with: openssl rand -hex 32
JWT_SECRET=change-me-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Security ──────────────────────────────────────────────────────────────────
# REQUIRED — set a unique value per deployment: openssl rand -hex 16
# All deployments sharing the same salt + JWT_SECRET can decrypt each other's
# stored API keys.
ENCRYPTION_SALT=change-me-unique-per-deployment

# ── BYOK — LLM Provider Keys ──────────────────────────────────────────────────
# Platform-level fallback keys. Leave blank to require per-user keys via the UI.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=

# ── Local AI base URLs ────────────────────────────────────────────────────────
# Set the URL that matches YOUR deployment for each local AI provider.
# Leave blank to disable (users can still set their own URL in the UI).
#
# Deployment scenarios:
#   AI on host, app in Docker  → http://host.docker.internal:<port>
#   AI as a Docker service     → http://<service-name>:<port>
#   Everything outside Docker  → http://localhost:<port>
#   Remote server              → http://<server-ip>:<port>

# Ollama (default port 11434)
OLLAMA_BASE_URL=

# llama.cpp server (default port 8080)
LLAMA_CPP_BASE_URL=

# vLLM (default port 8001)
VLLM_BASE_URL=

# GPT4All (default port 4891)
GPT4ALL_BASE_URL=

# Azure OpenAI (optional)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-02-01

# ── Application ───────────────────────────────────────────────────────────────
# Public-facing URLs — what the browser uses to reach the app
NEXT_PUBLIC_API_URL=http://localhost/api
NEXT_PUBLIC_WS_URL=ws://localhost/api/ws
NODE_ENV=development
APP_ENV=development

# Internal URL used by Jupyter kernels to call the API over the Docker network.
# Default works for standard docker-compose. Change if your API service has a
# different name or port.
INTERNAL_API_URL=http://api:8000

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost

# ── Feature Flags ─────────────────────────────────────────────────────────────
FEATURE_MLFLOW_ENABLED=true
FEATURE_JUPYTER_ENABLED=true
FEATURE_CONNECTORS_ENABLED=true
